<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — EventStream Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<nav class="admin-nav">
  <div class="nav-brand">
    <div class="nav-logo">
      <svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/><path d="M13 11l8 5-8 5V11z" fill="currentColor"/></svg>
    </div>
    <span>EventStream</span>
  </div>
  <div class="nav-actions">
    <span class="nav-badge">Admin</span>
    <a href="/admin/logout" class="nav-logout">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/></svg>
      Logout
    </a>
  </div>
</nav>

<main class="admin-main">
  <div class="page-header">
    <div>
      <h1>Live Events</h1>
      <p>Manage your YouTube Live streaming events</p>
    </div>
    <a href="/admin/events/new" class="btn-primary">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
      New Event
    </a>
  </div>

  <% if (events.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">
        <svg viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="30" stroke="currentColor" stroke-width="1.5" opacity="0.3"/><path d="M24 22l16 10-16 10V22z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
      </div>
      <h2>No events yet</h2>
      <p>Create your first live streaming event to get started</p>
      <a href="/admin/events/new" class="btn-primary">Create First Event</a>
    </div>
  <% } else { %>
    <div class="events-grid">
      <% events.forEach(event => { %>
        <div class="event-card ceremony-<%= event.ceremonyType.toLowerCase() %>">
          <div class="event-card-badge"><%= event.ceremonyType %></div>
          <div class="event-card-body">
            <h3><%= event.title %></h3>
            <div class="event-meta">
              <span>
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M5.5 0a.5.5 0 01.5.5V2h4V.5a.5.5 0 011 0V2h1a2 2 0 012 2v11a2 2 0 01-2 2H2a2 2 0 01-2-2V4a2 2 0 012-2h1V.5a.5.5 0 01.5-.5zM2 3a1 1 0 00-1 1v1h14V4a1 1 0 00-1-1H2zm13 3H1v9a1 1 0 001 1h12a1 1 0 001-1V6z"/></svg>
                <%= new Date(event.eventDate).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
              </span>
              <% if (event.eventTime) { %>
              <span>
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 3.5a.5.5 0 00-1 0V9a.5.5 0 00.252.434l3.5 2a.5.5 0 00.496-.868L8 8.71V3.5z"/><path d="M8 16A8 8 0 108 0a8 8 0 000 16zm7-8A7 7 0 111 8a7 7 0 0114 0z"/></svg>
                <%= event.eventTime %>
              </span>
              <% } %>
              <span>
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 16s6-5.686 6-10A6 6 0 002 6c0 4.314 6 10 6 10zm0-7a3 3 0 110-6 3 3 0 010 6z"/></svg>
                <%= event.location || 'No location' %>
              </span>
            </div>
          </div>
          <div class="event-card-actions">
            <a href="/event/<%= event.slug %>" target="_blank" class="btn-sm btn-view">
              <svg viewBox="0 0 16 16" fill="currentColor"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 011.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0114.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 011.172 8z"/><path d="M8 5.5a2.5 2.5 0 100 5 2.5 2.5 0 000-5zM4.5 8a3.5 3.5 0 117 0 3.5 3.5 0 01-7 0z"/></svg>
              View
            </a>
            <button class="btn-sm btn-copy" onclick="copyLink('/event/<%= event.slug %>', this)">
              <svg viewBox="0 0 16 16" fill="currentColor"><path d="M4 1.5H3a2 2 0 00-2 2V14a2 2 0 002 2h10a2 2 0 002-2V3.5a2 2 0 00-2-2h-1v1h1a1 1 0 011 1V14a1 1 0 01-1 1H3a1 1 0 01-1-1V3.5a1 1 0 011-1h1v-1z"/><path d="M9.5 1a.5.5 0 01.5.5v1a.5.5 0 01-.5.5h-3a.5.5 0 01-.5-.5v-1a.5.5 0 01.5-.5h3zm-3-1A1.5 1.5 0 005 1.5v1A1.5 1.5 0 006.5 4h3A1.5 1.5 0 0011 2.5v-1A1.5 1.5 0 009.5 0h-3z"/></svg>
              Copy Link
            </button>
            <a href="/admin/events/<%= event.id %>/edit" class="btn-sm btn-edit">
              <svg viewBox="0 0 16 16" fill="currentColor"><path d="M12.146.146a.5.5 0 01.708 0l3 3a.5.5 0 010 .708l-10 10a.5.5 0 01-.168.11l-5 2a.5.5 0 01-.65-.65l2-5a.5.5 0 01.11-.168l10-10zM11.207 2.5L13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 01.5.5v.5h.5a.5.5 0 01.5.5v.5h.293l6.5-6.5zm-9.761 5.175l-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 015 12.5V12h-.5a.5.5 0 01-.5-.5V11h-.5a.5.5 0 01-.468-.325z"/></svg>
              Edit
            </a>
            <form method="POST" action="/admin/events/<%= event.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this event?')">
              <button type="submit" class="btn-sm btn-delete">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M5.5 5.5A.5.5 0 016 6v6a.5.5 0 01-1 0V6a.5.5 0 01.5-.5zm2.5 0a.5.5 0 01.5.5v6a.5.5 0 01-1 0V6a.5.5 0 01.5-.5zm3 .5a.5.5 0 00-1 0v6a.5.5 0 001 0V6z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 01-1 1H13v9a2 2 0 01-2 2H5a2 2 0 01-2-2V4h-.5a1 1 0 01-1-1V2a1 1 0 011-1H6a1 1 0 011-1h2a1 1 0 011 1h3.5a1 1 0 011 1v1zM4.118 4L4 4.059V13a1 1 0 001 1h6a1 1 0 001-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z" clip-rule="evenodd"/></svg>
                Delete
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</main>

<script>
  function copyLink(path, btn) {
    const url = window.location.origin + path;
    navigator.clipboard.writeText(url).then(() => {
      const orig = btn.innerHTML;
      btn.textContent = 'Copied!';
      btn.style.background = 'var(--success)';
      btn.style.color = '#fff';
      setTimeout(() => { btn.innerHTML = orig; btn.style = ''; }, 2000);
    });
  }

  const hour = new Date().getHours();
  if (hour >= 17 || hour < 6) document.documentElement.setAttribute('data-theme', 'dark');
</script>
</body>
</html>
