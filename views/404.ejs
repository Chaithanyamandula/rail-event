<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found — EventStream</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;600&family=DM+Sans:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; text-align:center; }
    .notfound { max-width: 400px; padding: 2rem; }
    .notfound h1 { font-family: 'Cormorant Garamond', serif; font-size: 6rem; font-weight:300; line-height:1; color: var(--accent); margin:0; }
    .notfound h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; margin: .5rem 0 1rem; }
    .notfound p { color: var(--text-muted); margin-bottom: 2rem; }
  </style>
</head>
<body>
  <div class="notfound">
    <h1>404</h1>
    <h2>Event Not Found</h2>
    <p>This event page doesn't exist or may have been removed.</p>
    <a href="/admin/login" class="btn-primary" style="display:inline-flex;gap:.5rem;align-items:center;padding:.75rem 1.5rem;border-radius:8px;background:var(--accent);color:#fff;text-decoration:none;font-size:.875rem;">Go to Admin</a>
  </div>
  <script>
    const h = new Date().getHours();
    if (h >= 17 || h < 6) document.documentElement.setAttribute('data-theme', 'dark');
  </script>
</body>
</html>
